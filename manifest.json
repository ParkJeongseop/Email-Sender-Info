{
  "manifest_version": 3,
  "name": "__MSG_extensionName__",
  "version": "0.1.0",
  "default_locale": "en",
  "description": "__MSG_extensionDescription__",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "__MSG_actionTitle__"
  },
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/background.js"]
  },
  "host_permissions": [
    "https://www.google.com/s2/*",
    "https://*.gstatic.com/faviconV2*",
    "https://mail.google.com/*",
    "https://mail.naver.com/*",
    "https://mail.daum.net/*",
    "https://mail.kakao.com/*",
    "https://mail3.nate.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*",
    "https://www.icloud.com/*",
    "https://mail.yahoo.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/gmail.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.naver.com/*"],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/naver.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.daum.net/*",
        "https://mail.kakao.com/*"
      ],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/daum.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail3.nate.com/*"],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/nate.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/outlook.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.icloud.com/*"],
      "all_frames": true,
      "world": "MAIN",
      "js": ["src/adapters/icloud-interceptor.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.icloud.com/*"],
      "all_frames": true,
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/icloud.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.yahoo.com/*"],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/yahoo.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "email-sender-info@parkjeongseop.com",
      "strict_min_version": "128.0",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  }
}
