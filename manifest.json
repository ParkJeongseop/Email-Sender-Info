{
  "manifest_version": 3,
  "name": "Email Sender Info",
  "version": "0.1.0",
  "description": "Show sender favicons and a personal-mail indicator across Gmail, Naver, Daum and more.",
  "host_permissions": [
    "https://mail.google.com/*",
    "https://mail.naver.com/*",
    "https://mail.daum.net/*",
    "https://mail.kakao.com/*",
    "https://mail3.nate.com/*",
    "https://outlook.live.com/*",
    "https://outlook.office.com/*",
    "https://outlook.office365.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/gmail.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail.naver.com/*"],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/naver.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.daum.net/*",
        "https://mail.kakao.com/*"
      ],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/daum.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://mail3.nate.com/*"],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/nate.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://outlook.live.com/*",
        "https://outlook.office.com/*",
        "https://outlook.office365.com/*"
      ],
      "js": [
        "src/lib/personal-domains.js",
        "src/lib/icon-builder.js",
        "src/adapters/outlook.js"
      ],
      "css": ["src/styles/common.css"],
      "run_at": "document_idle"
    }
  ]
}
